{
    "name": "zilch-task",
    "version": "1.0.0",
    "private": true,
    "main": "index.ts",
    "scripts": {
        "start": "expo start -d",
        "android": "expo run:android",
        "android:release": "bun android --variant=release",
        "ios": "expo run:ios",
        "ios:release": "bun ios --configuration Release",
        "web": "expo start --web",
        "lint": "oxlint",
        "lint:fix": "oxlint --fix",
        "clean": "rm -rf node_modules && bun install",
        "prebuild": "expo prebuild",
        "prebuild:clean": "bun prebuild --clean",
        "type:check": "tsgo",
        "type:check:clean": "rm -f .tsbuildinfo && tsgo",
        "format:fix": "bun oxfmt --write",
        "format:fix:all": "bun oxfmt --write .",
        "format:check": "bun oxfmt --check",
        "test:e2e": "maestro test --debug-output .maestro/screenshots .maestro/flows/",
        "test:e2e:single": "maestro test",
        "test:unit:changed": "jest -o --watch --coverage=false",
        "test:unit:watch": "jest --watchAll",
        "test:unit": "jest",
        "test:unit:update": "jest -u --coverage=false"
    },
    "dependencies": {
        "@react-navigation/bottom-tabs": "^7.15.5",
