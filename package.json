        "expo-linking": "~55.0.13",
        "expo-local-authentication": "~55.0.13",
        "expo-localization": "~55.0.13",
        "expo-router": "~55.0.12",
        "expo-splash-screen": "~55.0.18",
        "expo-status-bar": "~55.0.5",
        "expo-store-review": "~55.0.13",
        "expo-system-ui": "~55.0.15",
        "i18next": "^26.0.4",
        "intl-pluralrules": "^2.0.1",
        "jotai": "^2.19.1",
        "react": "19.2.0",
        "react-dom": "19.2.0",
        "react-i18next": "^17.0.2",
        "react-native": "0.83.4",
        "react-native-actions-sheet": "^10.1.2",
